<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Anna Lucia Sams</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;600;700&family=Montserrat:wght@200;300&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      width: 100%;
      height: 100%;
      overflow: hidden;
    }

    body {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Full screen green forest background */
    .bg {
      position: fixed;
      inset: 0;
      background-image: url('https://images.unsplash.com/photo-1542273917363-3b1817f69a2d?w=1600&q=80');
      background-size: cover;
      background-position: center;
      z-index: 0;
      animation: slowZoom 20s ease-in-out infinite alternate;
    }

    @keyframes slowZoom {
      from { transform: scale(1); }
      to   { transform: scale(1.06); }
    }

    /* Dark overlay */
    .overlay {
      position: fixed;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(0,0,0,0.1) 0%,
        rgba(0, 30, 0, 0.3) 50%,
        rgba(0,0,0,0.6) 100%
      );
      z-index: 1;
    }

    /* Content */
    .content {
      position: relative;
      z-index: 2;
      text-align: center;
      padding: 20px;
    }

    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(5rem, 15vw, 11rem);
      font-weight: 300;
      color: #ffffff;
      letter-spacing: 8px;
      line-height: 1;
      text-shadow: 0 2px 40px rgba(0,0,0,0.5);
      animation: fadeIn 2s ease 0.2s forwards;
      opacity: 0;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .there {
      display: block;
      font-family: 'Cormorant Garamond', serif;
      font-weight: 600;
      letter-spacing: 14px;
      font-size: clamp(2rem, 6vw, 4.5rem);
      color: #ffffff;
      margin-top: -10px;
      text-shadow: 0 2px 40px rgba(0,0,0,0.5);
      animation: fadeIn 2s ease 0.6s forwards;
      opacity: 0;
    }

    .line {
      width: 80px;
      height: 1px;
      background: rgba(255,255,255,0.6);
      margin: 30px auto;
      animation: fadeIn 2s ease 1s forwards;
      opacity: 0;
    }

    .name {
      font-family: 'Montserrat', sans-serif;
      font-weight: 200;
      font-size: clamp(0.7rem, 2vw, 1rem);
      letter-spacing: 6px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.85);
      animation: fadeIn 2s ease 1.3s forwards;
      opacity: 0;
    }
  </style>
</head>
<body>

  <div class="bg"></div>
  <div class="overlay"></div>

  <div class="content">
    <h1>Hello</h1>
    <span class="there">There!</span>
    <div class="line"></div>
    <p class="name">Anna Lucia Sams</p>
  </div>

</body>
</html>
